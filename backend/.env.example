# App
APP_NAME=MySQL API Connector
APP_VERSION=0.1.0
DEBUG=true

# Metadata Database
# Dari dalam Docker container, gunakan host.docker.internal untuk akses MySQL di host lokal.
# Jika menjalankan backend langsung (tanpa Docker), gunakan 127.0.0.1 atau localhost.
DATABASE_SYNC_URL=mysql+pymysql://root@host.docker.internal:3306/mac_meta
DATABASE_URL=mysql+aiomysql://root@host.docker.internal:3306/mac_meta

# Redis
REDIS_URL=redis://redis:6379/0

# CORS
CORS_ORIGINS=["http://localhost:5173"]
